{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Finebro",
  "version": "0.1.0",
  "identifier": "com.meatlake.finebro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Finebro",
        "width": 1240,
        "height": 820,
        "minWidth": 390,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
